# Copy this file to .env and configure your credentials

# =============================================================================
# Model Provider Configuration
# =============================================================================

# Choose: "github" or "foundry"
MODEL_PROVIDER=github

# Model name (adjust based on provider)
# For GitHub Models: openai/gpt-4.1, openai/gpt-4o, openai/gpt-4.1-mini
# For Foundry: gpt-5-mini, gpt-5.1, gpt-4.1
MODEL_NAME=openai/gpt-4.1


# =============================================================================
# GitHub Models Configuration (Free tier available)
# =============================================================================

# Get your token from: https://github.com/settings/tokens
# Scopes needed: None (public access sufficient for models)
GITHUB_TOKEN=


# =============================================================================
# Microsoft Foundry Configuration (Production-ready)
# =============================================================================

# Your Azure AI Foundry project endpoint
# Example: https://my-project-abc123.api.azureml.ms
# FOUNDRY_PROJECT_ENDPOINT=

# Deployed model name in your Foundry project
# FOUNDRY_MODEL_DEPLOYMENT_NAME=gpt-5-mini


# =============================================================================
# Advanced Configuration (Optional)
# =============================================================================

# Logging level: DEBUG, INFO, WARNING, ERROR
# LOG_LEVEL=INFO

# HTTP server port (change if 8087 is in use)
# SERVER_PORT=8087

# Debug port (change if 5679 is in use)
# DEBUG_PORT=5679
